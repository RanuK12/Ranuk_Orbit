# Cloudflare Pages / Netlify headers
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Robots-Tag: index, follow

# Imágenes — cache largo (los nombres incluyen hash o slug único)
/media/optimized/*
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Videos — cache largo + range requests
/*.mp4
  Cache-Control: public, max-age=31536000, immutable
  Accept-Ranges: bytes
/*.webm
  Cache-Control: public, max-age=31536000, immutable
  Accept-Ranges: bytes

# Fuentes
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# JS/CSS — short cache so users pick up the new ?v=<hash> references
# quickly. The HTML is what carries the version pointer; once a locale
# HTML is revalidated, the ?v=<hash> URL changes and the browser treats
# the versioned asset as a brand-new resource regardless of its own
# cache policy.
/*.js
  Cache-Control: public, max-age=3600, must-revalidate
/*.jsx
  Cache-Control: public, max-age=3600, must-revalidate
/*.css
  Cache-Control: public, max-age=3600, must-revalidate

# HTML — revalidate on every load so new deploys are picked up without
# a hard reload. `no-cache` means "you may keep a copy but you must ask
# the server before using it"; combined with the ETag Cloudflare adds
# automatically, this is a single tiny conditional request per load.
/*.html
  Cache-Control: public, no-cache, must-revalidate
/
  Cache-Control: public, no-cache, must-revalidate
/en/*
  Cache-Control: public, no-cache, must-revalidate
/es/*
  Cache-Control: public, no-cache, must-revalidate
/it/*
  Cache-Control: public, no-cache, must-revalidate
